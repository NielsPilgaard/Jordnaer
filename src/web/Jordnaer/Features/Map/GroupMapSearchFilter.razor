@inject ILogger<GroupMapSearchFilter> Logger

@implements IAsyncDisposable

<LeafletMap @ref="_mapComponent" MapId="@MapId" InitialLatitude="@InitialLatitude"
    InitialLongitude="@InitialLongitude" InitialZoom="@InitialZoom"
    MapStyle="height: 450px; width: 100%; border-radius: 12px; border: 2px solid #e0e0e0; box-shadow: 0 2px 8px rgba(0,0,0,0.1);" />
<MudAlert Severity="Severity.Info" Variant="Variant.Text" Dense Class="mt-2">
    Grupper vises på postnummerniveau på kortet.
</MudAlert>

@code {
    private LeafletMap? _mapComponent;
    private IEnumerable<GroupMarkerData>? _previousGroups;
    private readonly CancellationTokenSource _cts = new();

    [Parameter]
    public string MapId { get; set; } = "group-map-search";

    [Parameter]
    public double InitialLatitude { get; set; } = 56.0; // Center of Denmark

    [Parameter]
    public double InitialLongitude { get; set; } = 10.0; // Center of Denmark

    [Parameter]
    public int InitialZoom { get; set; } = 7;

    /// <summary>
    /// Group markers to display on the map.
    /// </summary>
    [Parameter]
    public IEnumerable<GroupMarkerData>? Groups { get; set; }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            if (!await WaitForMapInitializationAsync(_cts.Token))
            {
                return;
            }

            if (Groups is not null)
            {
                var markers = Groups.ToList();
                _previousGroups = Groups;
                await _mapComponent!.UpdateGroupMarkersAsync(markers);
            }
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        if (_mapComponent?.IsInitialized != true)
        {
            return;
        }

        var markers = Groups?.ToList();
        if (markers is null || markers.Count == 0)
        {
            if (_previousGroups is not null)
            {
                _previousGroups = null;
                await _mapComponent.ClearGroupMarkersAsync();
            }
        }
        else if (Groups != _previousGroups)
        {
            _previousGroups = Groups;
            await _mapComponent.UpdateGroupMarkersAsync(markers);
        }
    }

    /// <summary>
    /// Gets the current map view state. Used to persist map state across navigation.
    /// </summary>
    public async Task<MapViewState?> GetMapStateAsync()
    {
        if (_mapComponent?.IsInitialized == true)
        {
            return await _mapComponent.GetMapStateAsync();
        }

        return null;
    }

    /// <summary>
    /// Restores a previously saved map view state.
    /// </summary>
    public async Task RestoreMapStateAsync(double viewLatitude, double viewLongitude, int zoom)
    {
        if (!await WaitForMapInitializationAsync(_cts.Token))
        {
            return;
        }

        await _mapComponent!.CenterMapAsync(viewLatitude, viewLongitude, zoom);
    }

    private async Task<bool> WaitForMapInitializationAsync(CancellationToken cancellationToken)
    {
        var attempts = 0;
        while (_mapComponent?.IsInitialized != true && attempts < 20)
        {
            try
            {
                await Task.Delay(50, cancellationToken);
            }
            catch (OperationCanceledException)
            {
                return false;
            }
            attempts++;
        }

        if (_mapComponent?.IsInitialized != true)
        {
            Logger.LogWarning(
                "WaitForMapInitializationAsync timed out after {Attempts} attempts ({Ms}ms). Map markers/state may not be restored.",
                attempts, attempts * 50);
            return false;
        }

        return true;
    }

    public async ValueTask DisposeAsync()
    {
        await _cts.CancelAsync();
        _cts.Dispose();
    }
}
