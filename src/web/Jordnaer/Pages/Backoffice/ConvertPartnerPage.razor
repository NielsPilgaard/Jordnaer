@page "/backoffice/partners/convert"

@using System.ComponentModel.DataAnnotations
@using Microsoft.EntityFrameworkCore

@inject IPartnerUserService PartnerService
@inject IDbContextFactory<JordnaerDbContext> ContextFactory
@inject ISnackbar Snackbar
@inject NavigationManager NavigationManager
@inject ILogger<ConvertPartnerPage> Logger

@attribute [Authorize(Policy = AuthorizationPolicies.AdminOnly)]

<MetadataComponent Title="Backoffice - Konverter Bruger til Partner"
    Description="Konverter en eksisterende bruger til partner." />

<MudStack Row AlignItems="AlignItems.Center" Class="mb-4">
    <MudIconButton Icon="@Icons.Material.Filled.ArrowBack"
                   Color="Color.Primary"
                   OnClick="NavigateToPartnerList" />
    <MudText Typo="Typo.h4">Konverter Bruger til Partner</MudText>
</MudStack>

<MudDivider Class="mb-5" />

<MudContainer MaxWidth="MaxWidth.Medium">
    @* Step 1: Search for user by name *@
    <MudPaper Class="pa-6" Elevation="2">
        <MudText Typo="Typo.h6" Class="mb-4">Find Bruger</MudText>

        <MudStack Row Spacing="2" AlignItems="AlignItems.Center">
            <MudTextField @bind-Value="_searchName"
                          Label="Navn eller brugernavn"
                          Variant="Variant.Outlined"
                          Placeholder="Søg efter bruger via navn..."
                          HelperText="Indtast brugerens fornavn, efternavn eller brugernavn"
                          Disabled="_isSearching || _isConverting"
                          Style="flex: 1;" />

            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Search"
                       OnClick="SearchUsersAsync"
                       Disabled="_isSearching || _isConverting || string.IsNullOrWhiteSpace(_searchName)">
                @if (_isSearching)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate Class="mr-2" />
                    <text>Søger...</text>
                }
                else
                {
                    <text>Søg</text>
                }
            </MudButton>
        </MudStack>

        @if (_searchError is not null)
        {
            <MudAlert Severity="Severity.Warning" Class="mt-4">@_searchError</MudAlert>
        }

        @if (_searchResults is not null && _selectedUser is null)
        {
            @if (_searchResults.Count == 0)
            {
                <MudAlert Severity="Severity.Warning" Class="mt-4">Ingen brugere fundet.</MudAlert>
            }
            else
            {
                <MudText Typo="Typo.body2" Class="mt-4 mb-2">@_searchResults.Count bruger(e) fundet. Vælg en bruger:</MudText>
                <MudList T="UserSearchItem" Dense>
                    @foreach (var user in _searchResults)
                    {
                        <MudListItem T="UserSearchItem"
                                     OnClick="() => SelectUserAsync(user)"
                                     Class="rounded mb-1"
                                     Style="cursor: pointer;">
                            <MudStack Row AlignItems="AlignItems.Center" Spacing="3">
                                <MudAvatar Size="Size.Small">
                                    @if (!string.IsNullOrEmpty(user.ProfilePictureUrl))
                                    {
                                        <MudImage Src="@user.ProfilePictureUrl" Alt="@user.DisplayName" />
                                    }
                                    else
                                    {
                                        <MudIcon Icon="@Icons.Material.Filled.Person" />
                                    }
                                </MudAvatar>
                                <MudStack Spacing="0">
                                    <MudText Typo="Typo.body1"><strong>@user.DisplayName</strong></MudText>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">@@@user.UserName</MudText>
                                </MudStack>
                                @if (user.IsAlreadyPartner)
                                {
                                    <MudChip T="string" Size="Size.Small" Color="Color.Warning">Allerede partner</MudChip>
                                }
                            </MudStack>
                        </MudListItem>
                    }
                </MudList>
            }
        }

        @if (_selectedUser is not null)
        {
            <MudAlert Severity="Severity.Success" Class="mt-4" Dense>
                <MudStack Row AlignItems="AlignItems.Center" Spacing="2">
                    <MudText Typo="Typo.body2">
                        Bruger valgt: <strong>@_selectedUser.DisplayName</strong> (@@@_selectedUser.UserName)
                    </MudText>
                    <MudIconButton Icon="@Icons.Material.Filled.Close"
                                   Size="Size.Small"
                                   OnClick="ClearSelection" />
                </MudStack>
            </MudAlert>
        }
    </MudPaper>

    @* Step 2: Partner details form (shown after user is selected) *@
    @if (_selectedUser is not null)
    {
        <MudPaper Class="pa-6 mt-4" Elevation="2">
            <EditForm Model="@_model" OnValidSubmit="ConvertToPartnerAsync">
                <DataAnnotationsValidator />
                <ValidationSummary />

                <MudStack Spacing="4">
                    <MudText Typo="Typo.h6" Class="mb-2">Partner Information</MudText>

                    <MudTextField @bind-Value="_model.PartnerName"
                                  Label="Partner Navn (valgfrit)"
                                  Variant="Variant.Outlined"
                                  HelperText="Navnet på virksomheden eller partneren (2-128 tegn)"
                                  MaxLength="128" />

                    <MudTextField @bind-Value="_model.Link"
                                  Label="Website URL (valgfrit)"
                                  Variant="Variant.Outlined"
                                  HelperText="Partnernes hjemmeside (fx https://example.com)"
                                  InputType="InputType.Url" />

                    <MudTextField @bind-Value="_model.Description"
                                  Label="Beskrivelse (valgfrit)"
                                  Variant="Variant.Outlined"
                                  Lines="4"
                                  HelperText="Kort beskrivelse af partneren (max 500 tegn)"
                                  MaxLength="500" />

                    <MudTextField @bind-Value="_model.LogoUrl"
                                  Label="Logo URL (valgfrit)"
                                  Variant="Variant.Outlined"
                                  HelperText="Link til partner logo billede"
                                  InputType="InputType.Url" />

                    <MudDivider Class="my-4" />

                    <MudText Typo="Typo.h6" Class="mb-2">Partner Tilladelser</MudText>

                    <MudSwitch @bind-Value="_model.CanHavePartnerCard"
                               Label="Tillad Partner Kort"
                               Color="Color.Primary"
                               Class="mb-2" />
                    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-3 ml-10">
                        Hvis aktiveret, kan partneren vises på /partners siden med logo og beskrivelse
                    </MudText>

                    <MudSwitch @bind-Value="_model.CanHaveAd"
                               Label="Tillad Annoncer"
                               Color="Color.Primary"
                               Class="mb-2" />
                    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-3 ml-10">
                        Hvis aktiveret, kan partneren uploade annonce billeder der vises i søgeresultater
                    </MudText>

                    <MudDivider Class="my-4" />

                    <MudAlert Severity="Severity.Info" Class="mb-4">
                        <MudText Typo="Typo.body2">
                            <strong>Bemærk:</strong> Når du konverterer brugeren, vil systemet:
                        </MudText>
                        <ul style="margin-top: 8px; margin-bottom: 0;">
                            <li>Oprette en partner-profil tilknyttet brugerens eksisterende konto</li>
                            <li>Tildele Partner-rollen til kontoen</li>
                            <li>Brugeren beholder alle eksisterende data (profil, grupper, chat, kontakter)</li>
                        </ul>
                    </MudAlert>

                    <MudStack Row Spacing="3" Justify="Justify.SpaceBetween">
                        <MudButton Variant="Variant.Outlined"
                                   Color="Color.Default"
                                   OnClick="ResetForm"
                                   Disabled="_isConverting">
                            Annuller
                        </MudButton>

                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   ButtonType="ButtonType.Submit"
                                   StartIcon="@Icons.Material.Filled.SwapHoriz"
                                   Disabled="_isConverting">
                            @if (_isConverting)
                            {
                                <MudProgressCircular Size="Size.Small" Indeterminate Class="mr-2" />
                                <text>Konverterer...</text>
                            }
                            else
                            {
                                <text>Konverter til Partner</text>
                            }
                        </MudButton>
                    </MudStack>
                </MudStack>
            </EditForm>
        </MudPaper>
    }

    @* Success result *@
    @if (_convertedPartner is not null)
    {
        <MudPaper Class="pa-6 mt-6" Elevation="2">
            <MudAlert Severity="Severity.Success" Class="mb-4">
                <MudText Typo="Typo.h6">Bruger Konverteret til Partner!</MudText>
            </MudAlert>

            <MudStack Spacing="3">
                <MudText Typo="Typo.body1">
                    Brugeren <strong>@_convertedPartner.DisplayName</strong> er nu en partner.
                </MudText>

                <MudAlert Severity="Severity.Info" Class="mt-2">
                    <MudText Typo="Typo.body2">
                        Brugeren skal logge ud og ind igen for at partner-rollen træder i kraft.
                    </MudText>
                </MudAlert>

                <MudDivider Class="my-2" />

                <MudStack Row Spacing="2">
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.Visibility"
                               OnClick="ViewPartnerDetails">
                        Se Partner Detaljer
                    </MudButton>

                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.SwapHoriz"
                               OnClick="ResetForm">
                        Konverter Endnu En Bruger
                    </MudButton>
                </MudStack>
            </MudStack>
        </MudPaper>
    }
</MudContainer>

@code {
    private string _searchName = string.Empty;
    private bool _isSearching;
    private bool _isConverting;
    private string? _searchError;
    private List<UserSearchItem>? _searchResults;
    private UserSearchItem? _selectedUser;
    private ConvertToPartnerResult? _convertedPartner;
    private ConvertPartnerModel _model = new();

    private record UserSearchItem(
        string UserId,
        string? DisplayName,
        string? UserName,
        string? ProfilePictureUrl,
        bool IsAlreadyPartner);

    private class ConvertPartnerModel
    {
        [StringLength(128, MinimumLength = 2, ErrorMessage = "Partner navn skal være mellem 2 og 128 tegn.")]
        public string? PartnerName { get; set; }

        [Url]
        public string? Link
        {
            get => field;
            set => field = string.IsNullOrWhiteSpace(value) ? null : value;
        }

        [MaxLength(500, ErrorMessage = "Beskrivelse må højst være 500 tegn.")]
        public string? Description { get; set; }

        [Url]
        public string? LogoUrl
        {
            get => field;
            set => field = string.IsNullOrWhiteSpace(value) ? null : value;
        }

        public bool CanHavePartnerCard { get; set; } = true;
        public bool CanHaveAd { get; set; } = true;
    }

    private async Task SearchUsersAsync()
    {
        if (string.IsNullOrWhiteSpace(_searchName))
            return;

        _isSearching = true;
        _searchError = null;
        _searchResults = null;
        _selectedUser = null;
        _convertedPartner = null;
        _model = new();

        try
        {
            await using var context = await ContextFactory.CreateDbContextAsync();
            var filter = _searchName.Trim();

            var partnerUserIds = context.Partners.AsNoTracking().Select(p => p.UserId);

            _searchResults = await context.UserProfiles
                .AsNoTracking()
                .Where(u => !string.IsNullOrEmpty(u.SearchableName) &&
                            EF.Functions.Like(u.SearchableName, $"%{filter}%"))
                .OrderBy(u => u.SearchableName)
                .Take(20)
                .Select(u => new UserSearchItem(
                    u.Id,
                    u.FirstName != null ? u.FirstName + " " + u.LastName : u.LastName,
                    u.UserName,
                    u.ProfilePictureUrl,
                    partnerUserIds.Contains(u.Id)))
                .ToListAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error searching for users by name");
            _searchError = "Der opstod en fejl under søgningen. Prøv igen.";
        }
        finally
        {
            _isSearching = false;
        }
    }

    private void SelectUserAsync(UserSearchItem user)
    {
        if (user.IsAlreadyPartner)
        {
            Snackbar.Add("Denne bruger er allerede en partner.", Severity.Warning);
            return;
        }

        _selectedUser = user;
        _model = new();

        // Pre-fill partner name from display name
        if (!string.IsNullOrWhiteSpace(user.DisplayName))
        {
            _model.PartnerName = user.DisplayName;
        }
    }

    private void ClearSelection()
    {
        _selectedUser = null;
        _model = new();
    }

    private async Task ConvertToPartnerAsync()
    {
        if (_selectedUser is null) return;

        var userId = _selectedUser.UserId;
        _isConverting = true;
        _convertedPartner = null;

        try
        {
            var request = new ConvertUserToPartnerRequest
            {
                UserId = userId,
                PartnerName = string.IsNullOrWhiteSpace(_model.PartnerName) ? null : _model.PartnerName,
                Link = string.IsNullOrWhiteSpace(_model.Link) ? null : _model.Link,
                Description = string.IsNullOrWhiteSpace(_model.Description) ? null : _model.Description,
                LogoUrl = string.IsNullOrWhiteSpace(_model.LogoUrl) ? null : _model.LogoUrl,
                CanHavePartnerCard = _model.CanHavePartnerCard,
                CanHaveAd = _model.CanHaveAd
            };

            var result = await PartnerService.ConvertUserToPartnerAsync(request);

            result.Switch(
                success =>
                {
                    _convertedPartner = success;
                    _selectedUser = null;
                    _searchResults = null;
                    Snackbar.Add("Bruger konverteret til partner!", Severity.Success);
                    Logger.LogInformation("Converted user {UserId} to partner", request.UserId);
                },
                error =>
                {
                    Snackbar.Add(error.Value, Severity.Error);
                    Logger.LogWarning("Failed to convert user to partner: {Error}", error.Value);
                }
            );
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Exception while converting user {UserId} to partner", userId);
            Snackbar.Add("Der opstod en uventet fejl. Prøv igen senere.", Severity.Error);
        }
        finally
        {
            _isConverting = false;
        }
    }

    private void ResetForm()
    {
        _searchName = string.Empty;
        _searchError = null;
        _searchResults = null;
        _selectedUser = null;
        _convertedPartner = null;
        _model = new();
    }

    private void NavigateToPartnerList()
    {
        NavigationManager.NavigateTo("/backoffice/partners");
    }

    private void ViewPartnerDetails()
    {
        if (_convertedPartner is not null)
        {
            NavigationManager.NavigateTo($"/backoffice/partners/{_convertedPartner.PartnerId}");
        }
    }
}
