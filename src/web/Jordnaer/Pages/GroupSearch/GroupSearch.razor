@page "/groups/discover"

@inject IGroupSearchService GroupSearchService
@inject NavigationManager Navigation
@inject GroupSearchResultCache Cache

@attribute [Sitemap]
@implements IDisposable

<MetadataComponent Title="Opdag Grupper" Description="Søg efter grupper" />

<MudLoading @bind-Loading="_isSearching" Darken Overlap>

    <GroupSearchForm OnFiltersChanged="OnFiltersChanged" @bind-Filter="_filter" Groups="@_searchResult.Groups" />

</MudLoading>

@code {

    private GroupSearchFilter _filter = new();
    private GroupSearchResult _searchResult = new();

    private bool _isSearching = false;
    private CancellationTokenSource? _debounceCts;
    private int _activeRequestId = 0;

    protected override async Task OnInitializedAsync()
    {
        // Restore from cache if available
        if (Cache.SearchFilter is not null && Cache.SearchResult is not null)
        {
            _filter = Cache.SearchFilter;
            _searchResult = Cache.SearchResult;
            return;
        }

        // Load all groups immediately on page visit
        await LoadGroupsAsync(_filter);
    }

    private async Task OnFiltersChanged()
    {
        _debounceCts?.Cancel();
        _debounceCts?.Dispose();
        _debounceCts = new CancellationTokenSource();
        try
        {
            await Task.Delay(400, _debounceCts.Token);
            await LoadGroupsAsync(_filter, _debounceCts.Token);
        }
        catch (OperationCanceledException) { /* superseded by newer keystroke */ }
    }

    private async Task LoadGroupsAsync(GroupSearchFilter filter, CancellationToken cancellationToken = default)
    {
        var requestId = ++_activeRequestId;
        _isSearching = true;
        try
        {
            _searchResult = await GroupSearchService.GetGroupsAsync(filter, cancellationToken);

            Cache.SearchFilter = _filter;
            Cache.SearchResult = _searchResult;

            StateHasChanged();
        }
        catch (OperationCanceledException) { /* superseded */ }
        finally
        {
            if (requestId == _activeRequestId)
            {
                _isSearching = false;
            }
        }
    }

    public void Dispose()
    {
        _debounceCts?.Cancel();
        _debounceCts?.Dispose();
    }
}
