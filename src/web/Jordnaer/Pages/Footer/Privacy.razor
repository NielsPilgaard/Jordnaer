@page "/privacy"

@inherits ScrollToTopComponentBase

<MetadataComponent Title="Privatlivspolitik" Description="Privatlivspolitik for Mini Møder" />

<MudContainer MaxWidth="MaxWidth.Medium">
    <MudPaper Elevation="3" Class="pa-10 mt-5" Style="@JordnaerPalette.WarmWhite.ToBackgroundColor()">

        <h1 class="font-cherry-bomb-one" style="@JordnaerPalette.BlueBody.ToTextColor()">
            Privatlivspolitik
        </h1>

        <MudDivider Class="mt-1 mb-5" />

        <MudText Typo="Typo.h5" Style="@JordnaerPalette.RedHeader.ToTextColor()">1. Introduktion</MudText>
        <MudText Typo="Typo.body1">
            Velkommen til Mini Møder. Vi er forpligtet til at beskytte dit privatliv og dine personlige oplysninger.
            Denne privatlivspolitik beskriver, hvordan vi indsamler, bruger, beskytter og deler dine personlige
            oplysninger, når du bruger vores tjenester.
        </MudText>

        <MudText Typo="Typo.h5" Class="mt-5" Style="@JordnaerPalette.RedHeader.ToTextColor()">2. Dataindsamling og
            anvendelse</MudText>
        <MudText Typo="Typo.body1">
            For at kunne levere vores tjenester indsamler vi forskellige typer af personlige oplysninger, herunder dit
            navn, e-mailadresse, kontaktoplysninger og eventuelle oplysninger om dine børn. Vi bruger disse oplysninger
            til at forbinde dig med andre forældre og arrangere sociale aktiviteter for børnene.
        </MudText>

        <MudText Typo="Typo.h5" Class="mt-5" Style="@JordnaerPalette.RedHeader.ToTextColor()">3. Deling af data
        </MudText>
        <MudText Typo="Typo.body1">
            Vi deler ikke dine personlige oplysninger med tredjeparter, medmindre det er nødvendigt for at levere vores
            tjenester eller som krævet af loven.
        </MudText>

        <MudText Typo="Typo.h5" Class="mt-5" Style="@JordnaerPalette.RedHeader.ToTextColor()">4. Datasikkerhed</MudText>
        <MudText Typo="Typo.body1">
            Vi tager din datasikkerhed alvorligt og træffer passende foranstaltninger for at beskytte dine personlige
            oplysninger mod uautoriseret adgang, ændring, videregivelse eller ødelæggelse.
        </MudText>

        <MudText Typo="Typo.h5" Class="mt-5" Style="@JordnaerPalette.RedHeader.ToTextColor()">5. Sletning af dine data</MudText>
        <MudText Typo="Typo.body1">
            Du har ret til at få dine personlige oplysninger slettet. Du kan selv slette alle dine data ved at slette
            din konto under kontoindstillinger. Alle dine oplysninger slettes ved kontosletning, medmindre vi er
            forpligtet til at bevare dem i henhold til lovkrav.
        </MudText>
        <MudText Typo="Typo.body1" Class="mt-2">
            Du kan også anmode om sletning af dine oplysninger ved at kontakte os på
            <MudLink Href="mailto:kontakt@mini-moeder.dk">kontakt@mini-moeder.dk</MudLink> med emnelinjen
            "Sletning af data". Vi vil behandle din anmodning inden for 30 dage.
            Bemærk, at visse oplysninger kan blive bevaret, hvis det er nødvendigt for at overholde lovkrav.
        </MudText>

        <MudText Typo="Typo.h5" Class="mt-5" Style="@JordnaerPalette.RedHeader.ToTextColor()">6. Ændringer i
            privatlivspolitikken</MudText>
        <MudText Typo="Typo.body1">
            Vi kan opdatere vores privatlivspolitik fra tid til anden. Vi vil informere dig om eventuelle væsentlige
            ændringer ved at sende en meddelelse på vores hjemmeside.
        </MudText>

        <Bees Class="mt-8" Center />

    </MudPaper>
</MudContainer>
