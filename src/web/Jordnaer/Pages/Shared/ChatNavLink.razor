@using Jordnaer.Features.Notifications
@using Jordnaer.Shared.Notifications

@inject NavigationManager Navigation
@inject CurrentUser CurrentUser
@inject INotificationService NotificationService
@inject NotificationSignalRClient NotificationSignalRClient
@inject ILogger<ChatNavLink> Logger

@implements IAsyncDisposable

@attribute [Authorize]

@if (_unreadMessageCount > 0)
{
    <a href="/chat" title="Chat">
        <MudBadge Origin="Origin.TopRight" Class="ml-2" Overlap Color="Color.Info" Content="@_unreadMessageCount">
            <MudIcon Icon="@Icons.Material.Filled.Chat" />
        </MudBadge>
    </a>
}
else
{
    <MudIconButton Href="/chat"
                   Icon="@Icons.Material.Filled.Chat"
                   title="Chat"/>
}

@code {
    private int _unreadMessageCount;
    private IDisposable? _notificationSubscription;
    private IDisposable? _unreadCountSubscription;

    protected override async Task OnInitializedAsync()
    {
        if (CurrentUser.Id is null)
        {
            return;
        }

        _unreadMessageCount = await NotificationService.GetUnreadCountByTypeAsync(
            CurrentUser.Id, NotificationType.ChatMessage);

        _notificationSubscription = NotificationSignalRClient.OnNotificationReceived(async notification =>
        {
            if (notification.Type == NotificationType.ChatMessage)
            {
                _unreadMessageCount++;
                await InvokeAsync(StateHasChanged);
            }
        });

        _unreadCountSubscription = NotificationSignalRClient.OnUnreadCountChanged(async _ =>
        {
            if (CurrentUser.Id is not null)
            {
                _unreadMessageCount = await NotificationService.GetUnreadCountByTypeAsync(
                    CurrentUser.Id, NotificationType.ChatMessage);
                await InvokeAsync(StateHasChanged);
            }
        });

        await NotificationSignalRClient.AcquireAsync();
    }

    public async ValueTask DisposeAsync()
    {
        _notificationSubscription?.Dispose();
        _unreadCountSubscription?.Dispose();
        await NotificationSignalRClient.ReleaseAsync();
    }
}
